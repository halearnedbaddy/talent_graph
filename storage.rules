rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos: owner can upload/update/delete their own photo
    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Profile videos: owner can upload/update/delete their own video
    match /profile-videos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
